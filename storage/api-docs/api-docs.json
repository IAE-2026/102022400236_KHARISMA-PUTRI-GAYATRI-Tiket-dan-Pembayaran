{
    "openapi": "3.0.0",
    "info": {
        "title": "Layanan Tiket dan Pembayaran Travel",
        "description": "EAI Ticket and Payment Service - 4 strategic endpoints (Listing, Detail, Payment, E-Ticket Issuance)",
        "contact": {
            "email": "102022400236@student.ac.id"
        },
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Docker / Local Development"
        }
    ],
    "paths": {
        "/api/v1/tickets": {
            "get": {
                "tags": [
                    "Tickets"
                ],
                "summary": "Daftar / riwayat pesanan tiket",
                "operationId": "listTickets",
                "parameters": [
                    {
                        "name": "status",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "booked",
                                "cancelled"
                            ]
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 15
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Daftar tiket",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        {
                                            "$ref": "#/components/schemas/ApiSuccess"
                                        },
                                        {
                                            "properties": {
                                                "data": {
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "IAEKey": []
                    }
                ]
            }
        },
        "/api/v1/tickets/{id}": {
            "get": {
                "tags": [
                    "Tickets"
                ],
                "summary": "Detail spesifik satu tiket",
                "operationId": "showTicket",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Detail tiket",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        {
                                            "$ref": "#/components/schemas/ApiSuccess"
                                        },
                                        {
                                            "properties": {
                                                "data": {
                                                    "$ref": "#/components/schemas/TicketData"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "IAEKey": []
                    }
                ]
            }
        },
        "/api/v1/tickets/{id}/payments": {
            "post": {
                "tags": [
                    "Tickets"
                ],
                "summary": "Proses pembayaran tiket berdasarkan ID",
                "operationId": "processTicketPayment",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "payment_method"
                                ],
                                "properties": {
                                    "payment_method": {
                                        "type": "string",
                                        "example": "QRIS",
                                        "enum": [
                                            "credit_card",
                                            "bank_transfer",
                                            "QRIS"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Pembayaran berhasil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        {
                                            "$ref": "#/components/schemas/ApiSuccess"
                                        },
                                        {
                                            "properties": {
                                                "data": {
                                                    "$ref": "#/components/schemas/PaymentData"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Ticket not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    },
                    "409": {
                        "description": "Payment already completed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "IAEKey": []
                    }
                ]
            }
        },
        "/api/v1/tickets/{id}/send": {
            "post": {
                "tags": [
                    "Tickets"
                ],
                "summary": "Kirim / tampilkan E-Ticket yang sudah lunas",
                "operationId": "sendETicket",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "E-Ticket berhasil dikeluarkan",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        {
                                            "$ref": "#/components/schemas/ApiSuccess"
                                        },
                                        {
                                            "properties": {
                                                "data": {
                                                    "$ref": "#/components/schemas/ETicketData"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    },
                    "402": {
                        "description": "Payment not completed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Ticket not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "IAEKey": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "ApiSuccess": {
                "properties": {
                    "status": {
                        "type": "string",
                        "example": "success"
                    },
                    "message": {
                        "type": "string",
                        "example": "Operation successful"
                    },
                    "data": {
                        "type": "object"
                    }
                },
                "type": "object"
            },
            "ApiError": {
                "properties": {
                    "status": {
                        "type": "string",
                        "example": "error"
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "example": null,
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "TicketData": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "cust_name": {
                        "type": "string",
                        "example": "Budi Santoso"
                    },
                    "route_id": {
                        "type": "integer",
                        "example": 10
                    },
                    "seat_number": {
                        "type": "string",
                        "example": "A12"
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "booked",
                            "cancelled"
                        ]
                    },
                    "price": {
                        "type": "number",
                        "format": "float",
                        "example": 150000
                    },
                    "payment": {
                        "$ref": "#/components/schemas/PaymentData"
                    }
                },
                "type": "object"
            },
            "PaymentData": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "ticket_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "amount": {
                        "type": "number",
                        "format": "float",
                        "example": 150000
                    },
                    "payment_method": {
                        "type": "string",
                        "enum": [
                            "credit_card",
                            "bank_transfer",
                            "QRIS"
                        ]
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "pending",
                            "completed",
                            "failed"
                        ]
                    },
                    "payment_date": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "ETicketData": {
                "properties": {
                    "ticket_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "e_ticket_code": {
                        "type": "string",
                        "example": "ETK-000001-ABC123"
                    },
                    "cust_name": {
                        "type": "string",
                        "example": "Budi Santoso"
                    },
                    "route_id": {
                        "type": "integer",
                        "example": 10
                    },
                    "seat_number": {
                        "type": "string",
                        "example": "A12"
                    },
                    "price": {
                        "type": "number",
                        "format": "float",
                        "example": 150000
                    },
                    "payment_status": {
                        "type": "string",
                        "example": "completed"
                    },
                    "issued_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "IAEKey": {
                "type": "apiKey",
                "description": "Kunci integrasi EAI - masukkan NIM: 102022400236 lalu klik Authorize",
                "name": "X-IAE-KEY",
                "in": "header"
            }
        }
    },
    "tags": [
        {
            "name": "Tickets",
            "description": "Siklus hidup tiket: listing, detail, pembayaran, e-ticket"
        }
    ]
}